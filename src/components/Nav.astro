---
import { site } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<div class="topline">
  <div class="container container-wide topline__inner">
    <span class="topline__sig">✦ Based in London, speaking worldwide</span>
    <span class="topline__sig topline__sig--right">{site.slogan}</span>
  </div>
</div>

<header class="nav" id="siteNav">
  <div class="container container-wide nav__inner">
    <a href="/" class="brand" aria-label={`${site.brand} — home`}>
      <span class="brand__mark">{site.brand}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {site.nav.map((item) => (
        <a href={item.href} class:list={['nav__link', { 'is-active': isActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>

    <a href={site.bookingUrl} class="btn nav__cta">
      {site.bookingLabel}<span class="arrow">→</span>
    </a>

    <button class="nav__toggle" id="navToggle" aria-expanded="false" aria-controls="mobileMenu">
      <span class="sr-only">Menu</span>
      <span class="nav__bars" aria-hidden="true"></span>
    </button>
  </div>

  <div class="mobile" id="mobileMenu" hidden>
    <nav class="mobile__nav" aria-label="Mobile">
      {site.nav.map((item) => (
        <a href={item.href} class="mobile__link">{item.label}</a>
      ))}
      <a href={site.bookingUrl} class="btn mobile__cta">{site.bookingLabel}<span class="arrow">→</span></a>
    </nav>
  </div>
</header>

<style>
  .topline {
    background: var(--ink-2);
    border-bottom: 1px solid var(--ink-3);
  }
  .topline__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 30px;
  }
  .topline__sig {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    color: rgba(244, 238, 224, 0.62);
  }
  .topline__sig--right { color: var(--canary); text-transform: uppercase; }
  @media (max-width: 640px) { .topline__sig--right { display: none; } }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--cream) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line-light);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 72px;
  }
  .brand__mark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: 0.04em;
    color: var(--ink);
  }
  .brand:hover .brand__mark { color: var(--canary-deep); }

  .nav__links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
  }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.4rem 0;
    position: relative;
    transition: color 0.2s ease;
  }
  .nav__link:hover, .nav__link.is-active { color: var(--ink); }
  .nav__link.is-active::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 100%; height: 2px;
    background: var(--canary);
  }

  .nav__cta { padding: 0.6em 1.1em; }

  .nav__toggle {
    display: none;
    margin-left: auto;
    width: 44px; height: 44px;
    background: transparent;
    border: 1px solid var(--line-light);
    border-radius: var(--radius);
    cursor: pointer;
    position: relative;
  }
  .nav__bars, .nav__bars::before, .nav__bars::after {
    content: '';
    position: absolute;
    left: 50%;
    width: 18px; height: 2px;
    background: var(--ink);
    transform: translateX(-50%);
    transition: transform 0.25s var(--ease), opacity 0.2s ease;
  }
  .nav__bars { top: 50%; transform: translate(-50%, -50%); }
  .nav__bars::before { top: -6px; }
  .nav__bars::after { top: 6px; }
  .nav__toggle[aria-expanded='true'] .nav__bars { background: transparent; }
  .nav__toggle[aria-expanded='true'] .nav__bars::before { transform: translateX(-50%) translateY(6px) rotate(45deg); }
  .nav__toggle[aria-expanded='true'] .nav__bars::after { transform: translateX(-50%) translateY(-6px) rotate(-45deg); }

  .mobile {
    border-bottom: 1px solid var(--line-light);
    background: var(--cream);
  }
  .mobile__nav {
    display: flex;
    flex-direction: column;
    padding: 1rem var(--gutter) 2rem;
    gap: 0.25rem;
  }
  .mobile__link {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--line-light);
  }
  .mobile__link:hover { color: var(--canary-deep); }
  .mobile__cta { margin-top: 1.25rem; justify-content: center; }

  @media (max-width: 900px) {
    .nav__links, .nav__cta { display: none; }
    .nav__toggle { display: block; }
  }
</style>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('mobileMenu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.hidden = open;
    });
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
      })
    );
  }
</script>
