---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found" description="That page has moved or never existed.">
  <section class="section nf">
    <div class="container">
      <p class="hud">▸ 404</p>
      <h1 class="nf__title">This page wandered off.</h1>
      <p class="lead muted">The link is broken or the page has moved. Let's get you back on track.</p>
      <div class="nf__actions">
        <a href="/" class="btn">Back home<span class="arrow">→</span></a>
        <a href="/writing" class="btn btn--ghost">Read the blog</a>
      </div>
    </div>
  </section>
  <style>
    .nf { padding-block: clamp(4rem, 3rem + 8vw, 9rem); }
    .nf__title { font-size: var(--step-4); margin: 1rem 0 1.2rem; }
    .nf__actions { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 2rem; }
  </style>
</Base>
