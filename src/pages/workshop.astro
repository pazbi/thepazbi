    .module__live::before { content: '→'; position: absolute; left: 0; color: var(--canary-deep); }
    .module__live span { font-family: var(--font-mono); font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.68rem; display: block; color: var(--muted); margin-bottom: 0.2rem; }

