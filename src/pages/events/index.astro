---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('events');
const now = new Date();
const upcoming = all.filter((e) => e.data.date >= now).sort((a, b) => a.data.date.getTime() - b.data.date.getTime());
const past = all.filter((e) => e.data.date < now).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
---
<Base title="Events" description="Where to catch Pazbi next: keynotes, workshops and firesides.">
  <PageHero eyebrow="▸ EVENTS" title="Where to catch me next." lede="Keynotes, workshops and conversations, public and private. Want me at yours?" />

  <section class="section">
    <div class="container">
      {upcoming.length > 0 ? (
        <>
          <p class="hud">▸ UPCOMING</p>
          <ul class="evlist">
            {upcoming.map((ev) => (
              <li class="ev reveal">
                <span class="ev__date">{fmt(ev.data.date)}</span>
                <span class="ev__type">{ev.data.type}</span>
                <span class="ev__title">{ev.data.title}</span>
                <span class="ev__loc muted">{ev.data.location}</span>
                {ev.data.url && <a class="ev__link" href={ev.data.url} target="_blank" rel="noopener">Details ↗</a>}
              </li>
            ))}
          </ul>
        </>
      ) : <p class="muted">No public dates listed. Get in touch to book one.</p>}
    </div>
  </section>

  {past.length > 0 && (
    <section class="section on-light">
      <div class="container">
        <p class="hud" style="color:var(--graphite)">▸ PAST</p>
        <ul class="evlist evlist--light">
          {past.map((ev) => (
            <li class="ev reveal">
              <span class="ev__date">{fmt(ev.data.date)}</span>
              <span class="ev__type">{ev.data.type}</span>
              <span class="ev__title">{ev.data.title}</span>
              <span class="ev__loc muted">{ev.data.location}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <style>
    .evlist { list-style: none; padding: 0; margin: 1.5rem 0 0; }
    .ev { display: grid; grid-template-columns: 130px 110px 1fr auto auto; gap: 1.5rem; align-items: center; padding: 1.4rem 0; border-top: 1px solid var(--line-light); }
    .ev:last-child { border-bottom: 1px solid var(--line-light); }
    .ev__date { font-family: var(--font-mono); font-size: 0.82rem; color: var(--canary-deep); letter-spacing: 0.04em; }
    .on-light .ev__title { color: var(--ink); }
    .ev__type { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); border: 1px solid currentColor; padding: 0.25em 0.6em; border-radius: 999px; width: fit-content; opacity: 0.7; }
    .ev__title { font-family: var(--font-display); font-weight: 600; font-size: var(--step-1); }
    .ev__link { font-family: var(--font-mono); font-size: 0.78rem; color: var(--canary-deep); }
    @media (max-width: 820px) { .ev { grid-template-columns: 1fr 1fr; gap: 0.5rem 1rem; } .ev__title { grid-column: 1 / -1; } }
  </style>
</Base>
