---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../lib/site';

const talks = [
  { code: 'SIGNATURE', title: 'How to Be Irreplaceable in an AI World', len: '45–60 min', desc: 'What AI changes, what it doesn\'t, and the moves that keep your people at the centre of it.' },
  { code: 'STRATEGY', title: 'The AI-Ready Leader', len: '30–45 min', desc: 'A practical playbook for executives who need to lead through AI without becoming engineers.' },
  { code: 'CULTURE', title: 'From Fear to Build', len: '45 min', desc: 'How to move a frozen team from anxiety to action, and make automation stick.' },
  { code: 'SME', title: 'Small Business, Big Leverage', len: '30 min', desc: 'The handful of AI moves that punch above their weight for owner-led businesses.' },
];
const formats = ['Conference keynotes', 'Leadership offsites', 'Award evenings', 'Panels & firesides', 'Virtual events'];
---
<Base title="Speaking" description="Book Pazbi Zavatzki to speak: keynotes on AI, digital transformation and staying irreplaceable.">
  <PageHero
    eyebrow="▸ KEYNOTES & TALKS"
    title="Talks that send people back to work different."
    lede="Funny, sharp, practical. No doom, no hype, only a clear view of AI and the confidence to act on it."
  >
    <div class="phead-actions"><a href={site.bookingUrl} class="btn">Check availability<span class="arrow">→</span></a></div>
  </PageHero>

  <section class="section on-light">
    <div class="container">
      <p class="hud" style="color:var(--graphite)">▸ TALKS</p>
      <div class="talks">
        {talks.map((t) => (
          <article class="talk reveal">
            <span class="talk__code">{t.code} · {t.len}</span>
            <h2 class="talk__title">{t.title}</h2>
            <p class="muted">{t.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section on-petrol">
    <div class="container organisers">
      <div class="reveal">
        <p class="hud hud--no-dot">FOR ORGANISERS</p>
        <h2 class="org__title">Easy to work with.<br />Built to land.</h2>
      </div>
      <ul class="org__list reveal">
        <li>Talks tailored to your audience and theme, never a canned deck</li>
        <li>A pre-event call to get the room right</li>
        <li>Clean tech rider, reliable comms, on time, every time</li>
        <li>Promo assets and post-event follow-up your attendees will use</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="hud">▸ FORMATS</p>
      <div class="formats">{formats.map((f) => <span class="format">{f}</span>)}</div>
    </div>
  </section>

  <style>
    .phead-actions { margin-top: 2rem; }
    .talks { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-top: 2rem; }
    .talk { padding: 1.8rem; background: var(--bone); border: 1px solid var(--line-light); border-radius: var(--radius-lg); }
    .talk__code { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; color: var(--canary-deep); }
    .talk__title { font-size: var(--step-2); color: var(--ink); margin: 0.8rem 0 0.8rem; }
    .organisers { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem,5vw,4rem); align-items: center; }
    .org__title { font-size: var(--step-3); color: var(--cream); }
    .org__list { list-style: none; padding: 0; display: grid; gap: 1rem; }
    .org__list li { padding-left: 1.6rem; position: relative; color: rgba(243,240,232,0.9); font-size: var(--step-1); }
    .org__list li::before { content: '▸'; position: absolute; left: 0; color: var(--canary); }
    .formats { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.5rem; }
    .format { font-family: var(--font-mono); font-size: 0.85rem; letter-spacing: 0.04em; border: 1px solid var(--line-light); padding: 0.6em 1em; border-radius: 999px; color: var(--graphite); }
    @media (max-width: 820px) { .talks, .organisers { grid-template-columns: 1fr; } }
  </style>
</Base>
