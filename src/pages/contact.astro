---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site, socialLinks } from '../lib/site';
---
<Base title="Book Pazbi" description="Book Pazbi to speak, run a workshop, or advise. Get in touch.">
  <PageHero
    eyebrow="▸ BOOKING · OPEN"
    title="Tell me what you're planning."
    lede="Keynote, workshop, or advisory: give me the shape of it and I'll come back fast with availability and a recommendation."
  />

  <section class="section">
    <div class="container contact">
      <div class="contact__form-wrap reveal">
        <!-- Handled by Netlify Forms. Submissions appear in the Netlify dashboard (Forms tab). -->
        <form class="cform" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/message-sent">
          <input type="hidden" name="form-name" value="contact" />
          <p class="cfield--hp" hidden>
            <label>Leave this empty: <input name="bot-field" /></label>
          </p>
          <div class="cfield">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required autocomplete="name" />
          </div>
          <div class="cfield">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required autocomplete="email" />
          </div>
          <div class="cfield">
            <label for="org">Organisation</label>
            <input id="org" name="organisation" type="text" />
          </div>
          <div class="cfield">
            <label for="type">What do you need?</label>
            <select id="type" name="engagement">
              <option>Keynote / talk</option>
              <option>Workshop</option>
              <option>Consultancy / advisory</option>
              <option>Something else</option>
            </select>
          </div>
          <div class="cfield cfield--full">
            <label for="msg">The shape of it</label>
            <textarea id="msg" name="message" rows="5" placeholder="Date, audience, what success looks like…"></textarea>
          </div>
          <button type="submit" class="btn cform__btn">Send it<span class="arrow">→</span></button>
        </form>
      </div>

      <aside class="contact__direct reveal">
        <p class="hud">▸ DIRECT</p>
        <a href={`mailto:${site.email}`} class="contact__email">{site.email}</a>
        <div class="contact__links">
          {socialLinks.map((s) => (
            <a href={s.href} target="_blank" rel="noopener">{s.label} ↗</a>
          ))}
        </div>
        <p class="muted contact__note">Based in London. Speaking worldwide, remote-friendly for workshops and advisory.</p>
      </aside>
    </div>
  </section>
  <style>
    .contact { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: clamp(2rem,5vw,4rem); align-items: start; }
    .cform { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .cfield { display: flex; flex-direction: column; gap: 0.5rem; }
    .cfield--full { grid-column: 1 / -1; }
    .cform label { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .cform input, .cform select, .cform textarea {
      background: #fff; border: 1px solid var(--line-light); border-radius: var(--radius);
      color: var(--ink); font-family: var(--font-body); font-size: var(--step-0); padding: 0.85em 1em; width: 100%;
    }
    .cform input:focus, .cform select:focus, .cform textarea:focus { border-color: var(--canary-deep); outline: none; box-shadow: 0 0 0 3px rgba(255,212,0,0.25); }
    .cform textarea { resize: vertical; }
    .cform__btn { grid-column: 1 / -1; justify-self: start; }
    .contact__email { font-family: var(--font-display); font-weight: 600; font-size: var(--step-1); color: var(--ink); display: block; margin: 1rem 0 1.5rem; }
    .contact__email:hover { color: var(--canary-deep); }
    .contact__links { display: flex; flex-wrap: wrap; gap: 0.8rem 1.5rem; }
    .contact__links a { font-family: var(--font-mono); font-size: 0.85rem; color: var(--canary-deep); }
    .contact__note { margin-top: 2rem; font-size: var(--step--1); }
    @media (max-width: 820px) { .contact { grid-template-columns: 1fr; } .cform { grid-template-columns: 1fr; } }
  </style>

  <script>
    // Prefill the form when arriving from a workshop "Book this workshop" link
    // (e.g. /contact?workshop=AI%20Day).
    const workshop = new URLSearchParams(window.location.search).get('workshop');
    if (workshop) {
      const select = document.getElementById('type') as HTMLSelectElement | null;
      if (select) select.value = 'Workshop';
      const message = document.getElementById('msg') as HTMLTextAreaElement | null;
      if (message && !message.value) {
        message.value = `I'd like to book the ${workshop}. `;
      }
    }
  </script>
</Base>
