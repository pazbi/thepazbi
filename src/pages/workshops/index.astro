---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { site } from '../../lib/site';
import { getCollection } from 'astro:content';

const workshops = (await getCollection('workshops')).sort((a, b) => a.data.order - b.data.order);
---
<Base title="Workshops" description="Hands-on AI and automation workshops. Your team ships working automations, not slideware.">
  <PageHero
    eyebrow="▸ WORKSHOPS & AI DAYS"
    title="Don't only hear about AI. Build with it."
    lede="Practical, build-in-the-room sessions where your team leaves with working automations and a plan you can run on Monday."
  >
    <div class="phead-actions"><a href={site.bookingUrl} class="btn">Plan a workshop<span class="arrow">→</span></a></div>
  </PageHero>

  <section class="section on-light">
    <div class="container">
      {workshops.map((w, i) => (
        <article class="wk reveal">
          <div class="wk__head">
            <span class="idx">0{i + 1}</span>
            <div>
              <h2 class="wk__title">{w.data.title}</h2>
              <p class="wk__tag">{w.data.tagline}</p>
            </div>
          </div>
          <div class="wk__grid">
            <div>
              <p class="muted wk__summary">{w.data.summary}</p>
              <ul class="wk__out">
                {w.data.outcomes.map((o) => <li>{o}</li>)}
              </ul>
            </div>
            <div class="wk__side">
              <dl class="wk__meta">
                <div><dt>Duration</dt><dd>{w.data.duration}</dd></div>
                <div><dt>Format</dt><dd>{w.data.format.join(' · ')}</dd></div>
                <div><dt>For</dt><dd>{w.data.audience}</dd></div>
                {w.data.price && <div><dt>Investment</dt><dd>{w.data.price}</dd></div>}
              </dl>
              <a href={`${site.bookingUrl}?workshop=${encodeURIComponent(w.data.title)}`} class="btn wk__cta">Book this workshop<span class="arrow">→</span></a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <style>
    .phead-actions { margin-top: 2rem; }
    .wk { padding: 2.5rem 0; border-top: 1px solid var(--line-light); }
    .wk:first-child { border-top: 0; padding-top: 0; }
    .wk__head { display: flex; gap: 1.2rem; align-items: baseline; margin-bottom: 1.5rem; }
    .wk__title { font-size: var(--step-3); color: var(--ink); }
    .wk__tag { font-family: var(--font-mono); font-size: 0.9rem; color: var(--canary-deep); margin-top: 0.4rem; }
    .wk__grid { display: grid; grid-template-columns: 1.4fr 0.6fr; gap: clamp(1.5rem,4vw,3rem); }
    .wk__summary { font-size: var(--step-0); margin-bottom: 1.5rem; }
    .wk__out { list-style: none; padding: 0; display: grid; gap: 0.7rem; }
    .wk__out li { padding-left: 1.6rem; position: relative; color: var(--ink); }
    .wk__out li::before { content: '▸'; position: absolute; left: 0; color: var(--canary-deep); }
    .wk__side { display: grid; gap: 1.6rem; align-content: start; border-left: 2px solid var(--canary); padding-left: 1.4rem; }
    .wk__meta { display: grid; gap: 1.1rem; }
    .wk__meta dt { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--graphite); }
    .wk__meta dd { color: var(--ink); margin-top: 0.2rem; }
    .wk__cta { justify-self: start; }
    @media (max-width: 820px) { .wk__grid { grid-template-columns: 1fr; } }
  </style>
</Base>
